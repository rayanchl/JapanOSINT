# Backend configuration. Copy to `.env` at the repo root; `npm run dev` and
# `npm run start` load it via `node --env-file=../.env`.

# ── Server basics ──────────────────────────────────────────────────────────
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173

# ── Multi-tenancy ──────────────────────────────────────────────────────────
# Off by default. Set to 1 once Supabase Auth + tenant resolution are
# wired into the route stack and the iOS app is sending bearer tokens.
MULTI_TENANT_ENABLED=0

# Supabase project's JWT secret (Project Settings → API → JWT Secret).
# HS256 signing key. Required when MULTI_TENANT_ENABLED=1.
SUPABASE_JWT_SECRET=

# Master key for tenant-secret encryption. Generate with:
#   openssl rand -base64 32
# Per-tenant keys are derived via HKDF-SHA256 (info=tenant_secrets.v1).
SECRETS_MASTER_KEY=

# ── Break-glass admin (Supabase outage path) ───────────────────────────────
# All three required to use POST /admin/break-glass/login.
# Keep off in normal operation; flip on during an incident, then rotate
# ADMIN_TOTP_SECRET afterwards.
BREAK_GLASS_ENABLED=0
ADMIN_TOTP_SECRET=                 # base32, set up in an authenticator app
BREAK_GLASS_JWT_SECRET=            # independent HS256 secret

# ── Upstream API keys (platform default; tenants can BYOK) ─────────────────
# Set only the ones you actually pay for. Free-tier sources work without.
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
WINDY_API_KEY=
GITHUB_TOKEN=
ODPT_TOKEN=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
GREYNOISE_API_KEY=
FOFA_API_KEY=
QUAKE_API_KEY=
EDINET_API_KEY=
HOTPEPPER_API_KEY=
OPENCELLID_KEY=
MARINETRAFFIC_API_KEY=
VESSELFINDER_API_KEY=
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=
RESAS_API_KEY=
ESTAT_API_KEY=
GOOGLE_MYMAPS_IDS=
WIGLE_API_KEY=
MLS_API_KEY=
TWITTER_BEARER_TOKEN=
FACEBOOK_ACCESS_TOKEN=
MISSKEY_TOKEN=
UMISHIRU_API_KEY=
USGS_M2M_TOKEN=
AERODATABOX_KEY=
OPENCHARGEMAP_KEY=
GRAYHAT_API_KEY=
MLIT_N02_GEOJSON_URL=

# ── LLM enrichment ─────────────────────────────────────────────────────────
LLM_VISION_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
